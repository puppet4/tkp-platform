KD_APP_NAME='Tenant Knowledge Platform'
KD_APP_ENV=dev
KD_APP_DEBUG=true
KD_API_PREFIX=/api
KD_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tenant_knowledge_platform

# auth
KD_AUTH_JWT_ALGORITHMS=HS256
KD_AUTH_JWT_ISSUER=
KD_AUTH_JWT_AUDIENCE=
KD_AUTH_JWKS_URL=
KD_AUTH_JWT_SECRET=your-secret-key-at-least-32-bytes-long-please-change-this
KD_AUTH_JWT_LEEWAY_SECONDS=30

# OpenAI API (REQUIRED for embeddings and LLM generation)
KD_OPENAI_API_KEY=sk-your-openai-api-key-here
KD_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
KD_OPENAI_CHAT_MODEL=gpt-4o-mini
KD_OPENAI_CHAT_TEMPERATURE=0.7
KD_OPENAI_CHAT_MAX_TOKENS=2000
KD_OPENAI_EMBEDDING_DIMENSIONS=1536

# Text chunking configuration
KD_CHUNK_SIZE=800
KD_CHUNK_OVERLAP=200
KD_EMBEDDING_BATCH_SIZE=100

# Retrieval configuration
KD_RETRIEVAL_TOP_K=5
KD_RETRIEVAL_SIMILARITY_THRESHOLD=0.7
KD_RETRIEVAL_DEFAULT_STRATEGY=hybrid
KD_RETRIEVAL_VECTOR_WEIGHT=0.5
KD_RETRIEVAL_FULLTEXT_WEIGHT=0.5
KD_RETRIEVAL_ENABLE_RERANK=false
KD_RETRIEVAL_ENABLE_QUERY_REWRITE=false

# Elasticsearch configuration (for full-text search)
KD_ELASTICSEARCH_ENABLED=false
KD_ELASTICSEARCH_HOSTS=http://localhost:9200
KD_ELASTICSEARCH_API_KEY=
KD_ELASTICSEARCH_USERNAME=
KD_ELASTICSEARCH_PASSWORD=
KD_ELASTICSEARCH_INDEX_NAME=tkp_chunks
KD_ELASTICSEARCH_VERIFY_CERTS=true

# Rerank configuration
KD_RERANK_PROVIDER=cohere
KD_RERANK_API_KEY=
KD_RERANK_MODEL=
KD_RERANK_TOP_N=5

# Query rewrite configuration
KD_QUERY_REWRITE_STRATEGY=expansion

# Observability configuration
KD_OBSERVABILITY_ENABLED=false
KD_OBSERVABILITY_SERVICE_NAME=tkp-api
KD_OBSERVABILITY_SERVICE_VERSION=1.0.0
KD_OBSERVABILITY_OTLP_ENDPOINT=http://localhost:4317
KD_OBSERVABILITY_ENABLE_TRACES=true
KD_OBSERVABILITY_ENABLE_METRICS=true
KD_OBSERVABILITY_ENABLE_LOGS=false
KD_OBSERVABILITY_LOG_FORMAT=json
KD_OBSERVABILITY_LOG_LEVEL=INFO

# Data governance configuration
KD_GOVERNANCE_ENABLE_RLS=false
KD_GOVERNANCE_ENABLE_PII_DETECTION=true
KD_GOVERNANCE_ENABLE_PII_MASKING=true
KD_GOVERNANCE_DELETION_REQUIRE_APPROVAL=true
KD_GOVERNANCE_RETENTION_ENABLED=false

# Agent advanced features configuration
KD_AGENT_ENABLE_SANDBOX=true
KD_AGENT_ENABLE_GUARDRAIL=true
KD_AGENT_SANDBOX_TIMEOUT=30
KD_AGENT_SANDBOX_MAX_MEMORY_MB=512
KD_AGENT_MAX_ITERATIONS=10
KD_AGENT_RATE_LIMIT_PER_MINUTE=60

# Kafka configuration
KD_KAFKA_ENABLED=false
KD_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KD_KAFKA_CLIENT_ID=tkp-api
KD_KAFKA_CONSUMER_GROUP_ID=tkp-api-group

# OCR configuration
KD_OCR_ENABLED=false
KD_OCR_ENGINE=tesseract
KD_OCR_LANGUAGE=eng+chi_sim

# Image parsing configuration
KD_IMAGE_DESCRIPTION_ENABLED=false
KD_IMAGE_THUMBNAIL_ENABLED=true
KD_IMAGE_THUMBNAIL_MAX_SIZE=300

# Table extraction configuration
KD_TABLE_EXTRACTION_ENABLED=false
KD_TABLE_EXTRACTION_METHOD=camelot

# ingestion + storage
KD_STORAGE_ROOT=./.storage
KD_STORAGE_BACKEND=local
KD_STORAGE_BUCKET=tkp-documents
KD_STORAGE_KEY_PREFIX=
KD_STORAGE_ENDPOINT=
KD_STORAGE_ACCESS_KEY=
KD_STORAGE_SECRET_KEY=
KD_STORAGE_REGION=
KD_STORAGE_SECURE=false
KD_INGESTION_DEFAULT_MAX_ATTEMPTS=5
KD_INGESTION_RETRY_BASE_SECONDS=15
KD_INGESTION_RETRY_MAX_SECONDS=1800

# agent governance
KD_AGENT_ALLOWED_TOOLS=retrieval

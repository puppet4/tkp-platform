# ============================================================================
# TKP Platform 环境变量配置模板
# ============================================================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 修改下方配置项，填入真实值
# 3. 生产环境必须修改所有标记为 [REQUIRED] 的配置项
# ============================================================================

# ----------------------------------------------------------------------------
# 应用基础配置
# ----------------------------------------------------------------------------
APP_NAME='Tenant Knowledge Platform'
APP_ENV=dev
APP_DEBUG=true
API_PREFIX=/api

# ----------------------------------------------------------------------------
# 数据库配置 [REQUIRED]
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tenant_knowledge_platform

# ----------------------------------------------------------------------------
# 认证配置 [REQUIRED]
# ----------------------------------------------------------------------------
AUTH_JWT_ALGORITHMS=HS256
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_JWKS_URL=
# [REQUIRED] 生产环境必须修改为强随机密钥（至少 32 字节）
AUTH_JWT_SECRET=your-secret-key-at-least-32-bytes-long-please-change-this
AUTH_JWT_LEEWAY_SECONDS=30

# ----------------------------------------------------------------------------
# Redis 配置（用于令牌黑名单和缓存）
# ----------------------------------------------------------------------------
# 可选：不配置时使用内存缓存
# REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# 内部服务鉴权 [REQUIRED]
# ----------------------------------------------------------------------------
# [REQUIRED] 生产环境必须修改
INTERNAL_SERVICE_TOKEN=change-me-internal-token-at-least-32-bytes

# ----------------------------------------------------------------------------
# OpenAI API 配置 [REQUIRED]
# ----------------------------------------------------------------------------
# [REQUIRED] 用于向量嵌入和 LLM 生成
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_TEMPERATURE=0.7
OPENAI_CHAT_MAX_TOKENS=2000
OPENAI_EMBEDDING_DIMENSIONS=1536

# Text chunking configuration
CHUNK_SIZE=800
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=100

# Retrieval configuration
RETRIEVAL_TOP_K=5
RETRIEVAL_SIMILARITY_THRESHOLD=0.7
RETRIEVAL_DEFAULT_STRATEGY=hybrid
RETRIEVAL_VECTOR_WEIGHT=0.5
RETRIEVAL_FULLTEXT_WEIGHT=0.5
RETRIEVAL_ENABLE_RERANK=false
RETRIEVAL_ENABLE_QUERY_REWRITE=false

# Elasticsearch configuration (for full-text search)
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_HOSTS=http://localhost:9200
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_NAME=tkp_chunks
ELASTICSEARCH_VERIFY_CERTS=true

# Rerank configuration
RERANK_PROVIDER=cohere
RERANK_API_KEY=
RERANK_MODEL=
RERANK_TOP_N=5

# Query rewrite configuration
QUERY_REWRITE_STRATEGY=expansion

# Observability configuration
OBSERVABILITY_ENABLED=false
OBSERVABILITY_SERVICE_NAME=tkp-api
OBSERVABILITY_SERVICE_VERSION=1.0.0
OBSERVABILITY_OTLP_ENDPOINT=http://localhost:4317
OBSERVABILITY_ENABLE_TRACES=true
OBSERVABILITY_ENABLE_METRICS=true
OBSERVABILITY_ENABLE_LOGS=false
OBSERVABILITY_LOG_FORMAT=json
OBSERVABILITY_LOG_LEVEL=INFO

# Data governance configuration
GOVERNANCE_ENABLE_RLS=false
GOVERNANCE_ENABLE_PII_DETECTION=true
GOVERNANCE_ENABLE_PII_MASKING=true
GOVERNANCE_DELETION_REQUIRE_APPROVAL=true
GOVERNANCE_RETENTION_ENABLED=false

# Agent advanced features configuration
AGENT_ENABLE_SANDBOX=true
AGENT_ENABLE_GUARDRAIL=true
AGENT_SANDBOX_TIMEOUT=30
AGENT_SANDBOX_MAX_MEMORY_MB=512
AGENT_MAX_ITERATIONS=10
AGENT_RATE_LIMIT_PER_MINUTE=60

# Kafka configuration
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=tkp-api
KAFKA_CONSUMER_GROUP_ID=tkp-api-group

# OCR configuration
OCR_ENABLED=false
OCR_ENGINE=tesseract
OCR_LANGUAGE=eng+chi_sim

# Image parsing configuration
IMAGE_DESCRIPTION_ENABLED=false
IMAGE_THUMBNAIL_ENABLED=true
IMAGE_THUMBNAIL_MAX_SIZE=300

# Table extraction configuration
TABLE_EXTRACTION_ENABLED=false
TABLE_EXTRACTION_METHOD=camelot

# Embedding Gateway configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_FALLBACK_PROVIDER=
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_TTL=86400
EMBEDDING_RATE_LIMIT_ENABLED=true
EMBEDDING_RATE_LIMIT_MAX=1000
EMBEDDING_RATE_LIMIT_WINDOW=60
COHERE_API_KEY=
COHERE_EMBEDDING_MODEL=embed-multilingual-v3.0
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Context Packing configuration
CONTEXT_MAX_TOKENS=4000
CONTEXT_RESERVE_TOKENS=500
CONTEXT_SIMILARITY_THRESHOLD=0.85
CONTEXT_PRIORITIZE_BY=score

# Answer Grading configuration
ANSWER_GRADING_ENABLED=true
ANSWER_CONFIDENCE_THRESHOLD=0.5
ANSWER_GRADING_RETRIEVAL_WEIGHT=0.4
ANSWER_GRADING_LLM_WEIGHT=0.4
ANSWER_GRADING_CITATION_WEIGHT=0.2
ANSWER_MIN_CITATION_COUNT=1
ANSWER_ENABLE_LLM_GRADING=true
ANSWER_GRADING_MODEL=gpt-4o-mini

# Parent-Child Chunk configuration
PARENT_CHILD_MERGE_ENABLED=true
PARENT_CHILD_MAX_MERGE_DISTANCE=2

# Sensitive Operation configuration
SENSITIVE_OPERATION_ENABLED=true
SENSITIVE_OPERATION_CONFIRMATION_TTL=300
SENSITIVE_OPERATION_CODE_LENGTH=6

# Query Preprocessing configuration
QUERY_LANGUAGE_DETECTION_ENABLED=true
QUERY_SPELL_CORRECTION_ENABLED=true
QUERY_NORMALIZATION_ENABLED=true

# Policy Score configuration
POLICY_SCORE_ENABLED=true
POLICY_RECENCY_WEIGHT=0.3
POLICY_AUTHORITY_WEIGHT=0.3
POLICY_PREFERENCE_WEIGHT=0.2
POLICY_BUSINESS_WEIGHT=0.2
POLICY_RELEVANCE_WEIGHT=0.7
POLICY_WEIGHT=0.3

# ----------------------------------------------------------------------------
# 对象存储配置
# ----------------------------------------------------------------------------
STORAGE_ROOT=./.storage
STORAGE_BACKEND=local
STORAGE_BUCKET=tkp-documents
STORAGE_KEY_PREFIX=
# MinIO/OSS 配置（当 STORAGE_BACKEND=minio 或 oss 时必填）
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=
STORAGE_SECURE=false

# ----------------------------------------------------------------------------
# 入库任务配置
# ----------------------------------------------------------------------------
INGESTION_DEFAULT_MAX_ATTEMPTS=5
INGESTION_RETRY_BASE_SECONDS=15
INGESTION_RETRY_MAX_SECONDS=1800

# ----------------------------------------------------------------------------
# Agent 配置
# ----------------------------------------------------------------------------
AGENT_ALLOWED_TOOLS=retrieval

# ============================================================================
# 生产环境检查清单
# ============================================================================
# 部署到生产环境前，请确保：
# 1. ✅ AUTH_JWT_SECRET 已修改为强随机密钥
# 2. ✅ INTERNAL_SERVICE_TOKEN 已修改为强随机密钥
# 3. ✅ OPENAI_API_KEY 已配置真实 API 密钥
# 4. ✅ DATABASE_URL 指向生产数据库
# 5. ✅ APP_DEBUG 设置为 false
# 6. ✅ APP_ENV 设置为 prod
# 7. ✅ 如使用 MinIO/OSS，已配置存储凭证
# 8. ✅ 如启用 Elasticsearch，已配置连接信息
# ============================================================================
